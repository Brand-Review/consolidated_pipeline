# BrandGuard AI Pipeline - Docker Environment Configuration

# Application Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false
PYTHONPATH=/app

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1

# File Upload Settings
MAX_FILE_SIZE=52428800
UPLOAD_DIR=/app/uploads
RESULTS_DIR=/app/results
MODELS_DIR=/app/models
LOGS_DIR=/app/logs

# Model Configuration
# Color Analysis
COLOR_N_COLORS=8
COLOR_TOLERANCE=0.2
ENABLE_CONTRAST_CHECK=true

# Typography Analysis
DISTANCE_THRESHOLD=20
TYPOGRAPHY_CONFIDENCE_THRESHOLD=0.7
MERGE_REGIONS=true

# Copywriting Analysis
INCLUDE_SUGGESTIONS=true
INCLUDE_INDUSTRY_BENCHMARKS=true
FORMALITY_SCORE=60
CONFIDENCE_LEVEL=balanced
WARMTH_SCORE=50
ENERGY_SCORE=50

# Logo Detection
ENABLE_PLACEMENT_VALIDATION=true
GENERATE_ANNOTATIONS=true
LOGO_CONFIDENCE_THRESHOLD=0.5
MAX_LOGO_DETECTIONS=100
PASS_THRESHOLD=0.7
WARNING_THRESHOLD=0.5
CRITICAL_THRESHOLD=0.3

# Analysis Settings
INCLUDE_RECOMMENDATIONS=true
ANALYSIS_PRIORITY=balanced
REPORT_DETAIL=detailed

# Database (if needed in future)
# DATABASE_URL=postgresql://user:password@db:5432/brandguard

# Redis (if needed in future)
# REDIS_URL=redis://redis:6379/0

# External APIs (if needed)
# OPENAI_API_KEY=your_openai_key
# HUGGINGFACE_API_KEY=your_hf_key

# Security
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
