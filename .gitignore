# =============================================================================
# BrandGuard consolidated_pipeline — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
.eggs/
MANIFEST
pip-wheel-metadata/
share/python-wheels/
pytest_cache/
.pytest_cache/
.pyre/


#all pycache directories
**/__pycache__/


# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
*.env
docker.env
!docker.env.example

# -----------------------------------------------------------------------------
# ML models & weights (large binaries — store in DVC or cloud)
# -----------------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.bin
*.safetensors
*.pkl
*.h5
*.pb
models/
# Exception: keep the directory itself
!models/.gitkeep

# -----------------------------------------------------------------------------
# Uploads & results (runtime data — not source code)
# -----------------------------------------------------------------------------
uploads/
results/
# Exception: keep the directory itself
!uploads/.gitkeep
!results/.gitkeep

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
server.log
test_output.log
logs/

# -----------------------------------------------------------------------------
# Test artifacts (old ad-hoc test files at root level)
# -----------------------------------------------------------------------------
test_results_*.json
response.json

# -----------------------------------------------------------------------------
# Eval reports (generated — not committed)
# -----------------------------------------------------------------------------
evals/reports/*.html
evals/reports/*.json
evals/reports/*.xml
# Keep the directory placeholder
!evals/reports/.gitkeep

# -----------------------------------------------------------------------------
# pytest / coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Docker runtime
# -----------------------------------------------------------------------------
*.pid

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# all upload folders
uploads/

./yolov8n.pt

./logs
